# Frontend
FRONTEND_URL=http://localhost:3000/

NODE_ENV=development

# Database
DB_URI="mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<app_name>"

